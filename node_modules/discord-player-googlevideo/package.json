{
  "name": "discord-player-googlevideo",
  "version": "0.2.2",
  "description": "A discord-player extractor using YouTube SABR streaming with googlevideo and youtubei.js",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "discord",
    "discord-player",
    "youtube",
    "extractor",
    "music",
    "streaming",
    "sabr",
    "youtubei",
    "googlevideo"
  ],
  "author": "xxczaki",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xxczaki/discord-bot.git",
    "directory": "packages/discord-player-googlevideo"
  },
  "bugs": {
    "url": "https://github.com/xxczaki/discord-bot/issues"
  },
  "homepage": "https://github.com/xxczaki/discord-bot/tree/main/packages/discord-player-googlevideo#readme",
  "peerDependencies": {
    "discord-player": "^7.1.0"
  },
  "dependencies": {
    "bgutils-js": "^3.2.0",
    "googlevideo": "^4.0.4",
    "jsdom": "^27.4.0",
    "youtubei.js": "^16.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.10.9",
    "@vitest/coverage-v8": "^4.0.18",
    "discord-player": "^7.2.0-dev.2",
    "typescript": "^5.9.3i",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "biome check --write ./src",
    "tsc": "tsc --noEmit",
    "test": "vitest run"
  }
}